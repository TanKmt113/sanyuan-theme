[{"key": "cable_lab_overview_text_1", "type": "wysiwyg", "original": "\n    <p style=\"font-size: 14px; line-height: 24px; text-align: left;\"><span style=\"line-height:1.2;\"><strong style=\"background-color: rgba(0, 0, 0, 0); font-size: 64px;\"><span style=\"color:#d40b1c;\">Cable&nbsp;</span><span style=\"color:#000000;\">Lab Overview</span></strong></span></p>\n\n", "label": "Cable Lab Overview", "section": "c_static_001-17657908566220"}, {"key": "cable_lab_overview_text_2", "type": "text", "original": "\n        SANYUAN conducts stringent testing to maintain premium product quality, \nwhich meets the strictest international or local standards.\n", "label": "SANYUAN conducts stringent testing to maintain premium p", "section": "c_static_001-17657908566220"}, {"key": "cable_lab_overview_img_1", "type": "image", "original": "../assets_img/2644c23d-811e-4523-b6dc-eedcbcb67a43_a9e5fe.png", "label": "2644c23d-811e-4523-b6dc-eedcbcb67a43_a9e5fe.png", "section": "c_static_001-17657908566220"}, {"key": "cable_lab_overview_text_3", "type": "wysiwyg", "original": "\n    <p style=\"text-align: center;\"><span style=\"font-size:24px;\"><span style=\"color:#000000;\">As a company, we are driven by people who strive for excellence. Our Cable Lab and cable experts with a goal of technical excellence are central to our customer commitment. Technical excellence means an ongoing commitment to product quality and compliance. We test hundreds of cables each week, remaining vigilant about non-compliance and sub-standard cables. Our team lends their wealth of knowledge to support client projects, through specification, modification, and regulatory compliance.</span></span></p>\n\n", "label": "As a company, we are driven by people who strive for exc", "section": "c_static_001-1763447308676"}, {"key": "cable_lab_overview_text_4", "type": "text", "original": "\n        Technical excellence is a big step on from Quality \nAssurance. lt's about achieving a tailored solution that\nmeets the installation demands now and in the future.\n", "label": "Technical excellence is a big step on from Quality Assur", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_5", "type": "wysiwyg", "original": "\n    <p style=\"font-size:14px;line-height:24px\"><strong><span style=\"color:#000000;\"><span style=\"font-size:54px;\">Regulatory&nbsp;</span></span></strong><span style=\"color:#d40b1c;\"><span style=\"font-size:54px;\">Compliance</span></span></p>\n\n", "label": "Regulatory Compliance", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_6", "type": "text", "original": "\n        Learn more about some of the regulations and legislation that we check our cables for compliance with.\n", "label": "Learn more about some of the regulations and legislation", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_7", "type": "text", "original": "\n        CPR\n", "label": "CPR", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_8", "type": "text", "original": "\n        Construction Products Regulation for cables\n", "label": "Construction Products Regulation for cables", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_9", "type": "text", "original": "\n        Low Voltage Directive\n", "label": "Low Voltage Directive", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_10", "type": "text", "original": "\n        EU Regulations for Harmonised standard cables to 1000V (AC) and 1500V (DC)\n", "label": "EU Regulations for Harmonised standard cables to 1000V (", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_11", "type": "text", "original": "\n        CE Mark\n", "label": "CE Mark", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_12", "type": "text", "original": "\n        European market approved product assurance\n", "label": "European market approved product assurance", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_13", "type": "text", "original": "\n        REACH\n", "label": "REACH", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_14", "type": "text", "original": "\n        Assessing against strict regulations on chemical substances\n", "label": "Assessing against strict regulations on chemical substan", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_15", "type": "text", "original": "\n        RoHS\n", "label": "RoHS", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_text_16", "type": "text", "original": "\n        X-ray spectrometry testing and GCMS testing\n", "label": "X-ray spectrometry testing and GCMS testing", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_img_2", "type": "image", "original": "../assets_img/6b8b5035-279e-44db-86c4-5ade5126b6b4_c8d5e1.jpg", "label": "6b8b5035-279e-44db-86c4-5ade5126b6b4_c8d5e1.jpg", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_img_3", "type": "image", "original": "../assets_img/ae40163f-f5d4-46ac-9f2b-25da97356630_0b0780.png", "label": "ae40163f-f5d4-46ac-9f2b-25da97356630_0b0780.png", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_img_4", "type": "image", "original": "../assets_img/830f2d23-1208-4819-bdeb-11f06c6406c1_0c9776.png", "label": "830f2d23-1208-4819-bdeb-11f06c6406c1_0c9776.png", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_img_5", "type": "image", "original": "../assets_img/94505839-730f-49f2-8572-3521ec3746bc_dbc0ec.png", "label": "94505839-730f-49f2-8572-3521ec3746bc_dbc0ec.png", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_img_6", "type": "image", "original": "../assets_img/b544b7c2-41ff-4d36-bb6d-fd2b6fbebd1e_56004d.png", "label": "b544b7c2-41ff-4d36-bb6d-fd2b6fbebd1e_56004d.png", "section": "c_static_001-1763447542414"}, {"key": "cable_lab_overview_img_7", "type": "image", "original": "../assets_img/304b5d50-a93b-41e7-a9d3-a58069b84865_ec1ef3.png", "label": "304b5d50-a93b-41e7-a9d3-a58069b84865_ec1ef3.png", "section": "c_static_001-1763447542414"}]